	"item": [
		{
			"name": "Assets",
			"item": [
				{
					"name": "Get All Assets",
					"request": {
						"method": "GET",
						"url": "http://localhost/InizioPHP/Zucchetti /api/assets.php"
					}
				},
				{
					"name": "Get Asset by ID",
					"request": {
						"method": "GET",
						"url": "http://localhost/InizioPHP/Zucchetti /api/assets.php?id=1"
					}
				},
				{
					"name": "Create Asset",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"codice_univoco\": \"NEW-01\",\n    \"id_tipo\": 1,\n    \"stato_attuale\": \"disponibile\"\n}"
						},
						"url": "http://localhost/InizioPHP/Zucchetti /api/assets.php"
					}
				},
				{
					"name": "Update Asset",
					"request": {
						"method": "PUT",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"stato_attuale\": \"non_prenotabile\"\n}"
						},
						"url": "http://localhost/InizioPHP/Zucchetti /api/assets.php?id=1"
					}
				},
				{
					"name": "Delete Asset",
					"request": {
						"method": "DELETE",
						"url": "http://localhost/InizioPHP/Zucchetti /api/assets.php?id=1"
					}
				}
			]
		},
